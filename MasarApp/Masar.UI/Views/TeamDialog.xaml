<Window x:Class="Masar.UI.Views.TeamDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{DynamicResource Title.Team}" Height="600" Width="720" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.TeamDetails}" FontSize="18" FontWeight="SemiBold" />

            <!-- Team Info -->
            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="{DynamicResource Label.TeamName}" />
                    <TextBox Text="{Binding Team.Name}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,0">
                    <TextBlock Text="{DynamicResource Label.College}" />
                    <ComboBox ItemsSource="{Binding Colleges}" DisplayMemberPath="NameEn" SelectedValuePath="CollegeId" SelectedValue="{Binding SelectedCollegeId}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="0">
                    <TextBlock Text="{DynamicResource Label.EnrollmentYear}" />
                    <ComboBox ItemsSource="{Binding EnrollmentYears}" SelectedItem="{Binding SelectedEnrollmentYear}" />
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,8,12,0">
                    <TextBlock Text="{DynamicResource Label.Department}" />
                    <ComboBox ItemsSource="{Binding Departments}" DisplayMemberPath="NameEn" SelectedValuePath="DepartmentId" SelectedValue="{Binding SelectedDepartmentId}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,8,12,0">
                    <TextBlock Text="{DynamicResource Label.Supervisor}" />
                    <ComboBox ItemsSource="{Binding Supervisors}" DisplayMemberPath="FullName" SelectedValuePath="DoctorId" SelectedValue="{Binding Team.SupervisorId}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Label.Committee}" />
                    <ComboBox ItemsSource="{Binding Committees}" DisplayMemberPath="Name" SelectedValuePath="CommitteeId" SelectedValue="{Binding Team.CommitteeId}" />
                </StackPanel>
            </Grid>

            <!-- Students Selection -->
            <GroupBox Grid.Row="2" Header="{DynamicResource Label.SelectStudents}" Margin="0,12,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding AvailableStudents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StudentNumber}" FontWeight="SemiBold" Width="100" />
                                        <TextBlock Text="{Binding FullName}" />
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </GroupBox>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
