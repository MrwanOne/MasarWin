<Window x:Class="Masar.UI.Views.CollegeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.College}" Height="360" Width="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.CollegeDetails}" FontSize="18" FontWeight="SemiBold" />

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Label.CollegeNameAr}" />
                    <TextBox Text="{Binding College.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Label.CollegeNameEn}" />
                    <TextBox Text="{Binding College.NameEn}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{DynamicResource Label.CollegeCode}" />
                    <TextBox Text="{Binding College.Code}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
