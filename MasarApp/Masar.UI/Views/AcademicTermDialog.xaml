<Window x:Class="Masar.UI.Views.AcademicTermDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Masar.UI.Converters"
        Title="{Binding Title}" Height="520" Width="540" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Window.Resources>
        <converters:SemesterConverter x:Key="SemesterConverter" />
    </Window.Resources>
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="{DynamicResource Label.Year}" />
                        <TextBox Text="{Binding Year}" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                        <TextBlock Text="{DynamicResource Label.Semester}" />
                        <ComboBox SelectedIndex="{Binding Semester, Converter={StaticResource SemesterConverter}}">
                            <ComboBoxItem Content="1 - الأول" />
                            <ComboBoxItem Content="2 - الثاني" />
                            <ComboBoxItem Content="3 - الصيفي" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Label.TermNameAr}" />
                        <TextBox Text="{Binding NameAr}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Label.TermNameEn}" />
                        <TextBox Text="{Binding NameEn}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,8">
                        <TextBlock Text="{DynamicResource Label.StartDate}" />
                        <DatePicker SelectedDate="{Binding StartDate}" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,8">
                        <TextBlock Text="{DynamicResource Label.EndDate}" />
                        <DatePicker SelectedDate="{Binding EndDate}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <CheckBox IsChecked="{Binding IsActive}" />
                        <TextBlock Text="{DynamicResource Label.IsActiveDescription}" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
