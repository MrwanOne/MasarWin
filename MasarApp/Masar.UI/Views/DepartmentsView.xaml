<UserControl x:Class="Masar.UI.Views.DepartmentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{DynamicResource Title.Departments}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource Subtitle.Departments}" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                        <TextBlock Text="{DynamicResource Label.College}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox ItemsSource="{Binding Colleges}"  SelectedValuePath="CollegeId" SelectedValue="{Binding SelectedCollegeId}" Width="200" Margin="0,0,16,0" >
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ., Converter={StaticResource LocalizedNameConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Width="180" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Button.Search}" Command="{Binding SearchCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Button.Refresh}" Command="{Binding RefreshCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </DockPanel>
                <WrapPanel Margin="0,12,0,0">
                    <Button Content="{DynamicResource Button.Add}" Command="{Binding AddCommand}" Margin="0,0,8,0" Visibility="{Binding CanManage, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{DynamicResource Button.Edit}" Command="{Binding EditCommand}" Margin="0,0,8,0" Visibility="{Binding CanManage, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{DynamicResource Button.Delete}" Command="{Binding DeleteCommand}" Margin="0,0,8,0" Visibility="{Binding CanManage, Converter={StaticResource BoolToVisibilityConverter}}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding PagedItems}" SelectedItem="{Binding SelectedDepartment}" Margin="0,12,0,12" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Grid.Department}" Binding="{Binding NameAr}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.DepartmentHead}" Binding="{Binding HeadOfDepartmentName}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.College}" Binding="{Binding CollegeName}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="{DynamicResource Button.Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
            <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock Text="/" Margin="4,0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" />
            <Button Content="{DynamicResource Button.Next}" Command="{Binding NextPageCommand}" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
