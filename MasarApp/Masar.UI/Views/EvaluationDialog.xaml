<Window x:Class="Masar.UI.Views.EvaluationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.Evaluation}" Height="520" Width="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.Evaluation}" FontSize="18" FontWeight="SemiBold" />

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,12">
                        <TextBlock Text="{DynamicResource Label.SupervisorScore}" />
                        <TextBox Text="{Binding SupervisorScore}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Label.CommitteeScore}" />
                        <TextBox Text="{Binding CommitteeScore}" />
                    </StackPanel>

                    <StackPanel Grid.ColumnSpan="2" Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Label.ReportNotes}" />
                        <TextBox Text="{Binding ReportText}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" />
                    </StackPanel>

                    <StackPanel Grid.ColumnSpan="2" Grid.Row="2" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Label.ReportFile}" />
                        <TextBox Text="{Binding ReportFilePath}" />
                    </StackPanel>

                    <StackPanel Grid.ColumnSpan="2" Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,8">
                        <Button Content="{DynamicResource Button.UploadReport}" Command="{Binding UploadReportCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
