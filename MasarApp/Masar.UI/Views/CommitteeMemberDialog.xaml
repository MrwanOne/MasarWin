<Window x:Class="Masar.UI.Views.CommitteeMemberDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{DynamicResource Title.AssignDoctor}" Height="320" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <StackPanel>
            <TextBlock Text="{DynamicResource Title.AssignDoctor}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{DynamicResource Label.Doctor}" Margin="0,12,0,0" />
            <ComboBox ItemsSource="{Binding Doctors}" DisplayMemberPath="FullName" SelectedItem="{Binding SelectedDoctor}" />
            <CheckBox Content="{DynamicResource Label.Chair}" Margin="0,12,0,0" IsChecked="{Binding IsChair}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
