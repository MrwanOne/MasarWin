<Window x:Class="Masar.UI.Views.DepartmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{DynamicResource Title.Department}" Height="420" Width="560" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.DepartmentDetails}" FontSize="18" FontWeight="SemiBold" />

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Label.College}" />
                    <ComboBox ItemsSource="{Binding Colleges}" DisplayMemberPath="NameEn" SelectedValuePath="CollegeId" SelectedValue="{Binding SelectedCollegeId}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Label.DepartmentNameAr}" />
                    <TextBox Text="{Binding Department.NameAr}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="{DynamicResource Label.DepartmentCode}" />
                    <TextBox Text="{Binding Department.Code}" />
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="{DynamicResource Label.HeadOfDepartment}" />
                    <ComboBox ItemsSource="{Binding Doctors}" DisplayMemberPath="FullName" SelectedValuePath="DoctorId" SelectedValue="{Binding Department.HeadOfDepartmentId}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
