<UserControl x:Class="Masar.UI.Views.StudentsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{DynamicResource Title.Students}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{DynamicResource Subtitle.Students}" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="12,0,0,0">
                        <ComboBox Width="180" ItemsSource="{Binding Departments}" DisplayMemberPath="NameEn" SelectedValuePath="DepartmentId" SelectedValue="{Binding SelectedDepartmentId}" Margin="0,0,8,0" />
                        <TextBox Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Button.Search}" Command="{Binding SearchCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Button.Refresh}" Command="{Binding RefreshCommand}" Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </DockPanel>
                <WrapPanel Margin="0,12,0,0">
                    <Button Content="{DynamicResource Button.ImportExcel}" Command="{Binding ImportFromExcelCommand}" Margin="0,0,8,0" />
                    <Button Content="{DynamicResource Button.Add}" Command="{Binding AddCommand}" Margin="0,0,8,0" Visibility="{Binding ShowManageButtons, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{DynamicResource Button.Edit}" Command="{Binding EditCommand}" Margin="0,0,8,0" Visibility="{Binding ShowManageButtons, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Content="{DynamicResource Button.Delete}" Command="{Binding DeleteCommand}" Margin="0,0,8,0" Visibility="{Binding ShowManageButtons, Converter={StaticResource BoolToVisibilityConverter}}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" ItemsSource="{Binding PagedItems}" SelectedItem="{Binding SelectedStudent}" Margin="0,12,0,12" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Grid.College}" Binding="{Binding CollegeName}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.StudentNumber}" Binding="{Binding StudentNumber}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.Name}" Binding="{Binding FullName}" Width="2*" />
                <DataGridTextColumn Header="{DynamicResource Grid.Department}" Binding="{Binding DepartmentName}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.Team}" Binding="{Binding TeamName}" Width="*" />
                <DataGridTextColumn Header="{DynamicResource Grid.Email}" Binding="{Binding Email}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="{DynamicResource Button.Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
            <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock Text="/" Margin="4,0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center" />
            <Button Content="{DynamicResource Button.Next}" Command="{Binding NextPageCommand}" Style="{StaticResource GhostButtonStyle}" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</UserControl>
