<Window x:Class="Masar.UI.Views.ProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{DynamicResource Title.Project}" Height="600" Width="720" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid>
        <Border Style="{StaticResource CardStyle}" Margin="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Title.ProjectDetails}" FontSize="18" FontWeight="SemiBold" />

                <ScrollViewer Grid.Row="1">
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Label.Title}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0">
                            <TextBlock Text="{DynamicResource Label.Status}" />
                            <ComboBox ItemsSource="{Binding StatusOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedStatus}" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Label.College}" />
                            <ComboBox ItemsSource="{Binding Colleges}"  SelectedValuePath="CollegeId" SelectedValue="{Binding SelectedCollegeId}" >
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ., Converter={StaticResource LocalizedNameConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1">
                            <TextBlock Text="{DynamicResource Label.Department}" />
                            <ComboBox ItemsSource="{Binding Departments}"  SelectedValuePath="DepartmentId" SelectedValue="{Binding SelectedDepartmentId}" >
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ., Converter={StaticResource LocalizedNameConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Label.Team}" />
                            <ComboBox ItemsSource="{Binding Teams}" SelectedValuePath="TeamId" SelectedValue="{Binding Project.TeamId}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text=" - " Foreground="Gray" />
                                            <TextBlock Text="{Binding StudentNames}" Foreground="Gray" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="{DynamicResource Label.Supervisor}" />
                            <ComboBox ItemsSource="{Binding Supervisors}" DisplayMemberPath="FullName" SelectedValuePath="DoctorId" SelectedValue="{Binding Project.SupervisorId}" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Label.Beneficiary}" />
                            <TextBox Text="{Binding Beneficiary, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="3">
                            <TextBlock Text="{DynamicResource Label.CompletionRate}" />
                            <TextBox Text="{Binding CompletionRate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                        </StackPanel>

                        <StackPanel Grid.ColumnSpan="2" Grid.Row="4">
                            <TextBlock Text="{DynamicResource Label.Description}" />
                            <TextBox Text="{Binding Project.Description}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" />
                        </StackPanel>

                        <StackPanel Grid.ColumnSpan="2" Grid.Row="5">
                            <TextBlock Text="{DynamicResource Label.DocumentationPath}" />
                            <TextBox Text="{Binding Project.DocumentationPath}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                    <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
