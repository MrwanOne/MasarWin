<Window x:Class="Masar.UI.Views.DiscussionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.Discussion}" Height="480" Width="620" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.DiscussionSchedule}" FontSize="18" FontWeight="SemiBold" />

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="2" Grid.Row="0" Margin="0,0,0,0">
                    <TextBlock Text="{DynamicResource Label.College}" />
                    <ComboBox ItemsSource="{Binding Colleges}" DisplayMemberPath="NameAr" SelectedValuePath="CollegeId" SelectedValue="{Binding SelectedCollegeId}" />
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,8,12,0">
                    <TextBlock Text="{DynamicResource Label.Team}" />
                    <ComboBox ItemsSource="{Binding Teams}" DisplayMemberPath="Name" SelectedValuePath="TeamId" SelectedValue="{Binding Discussion.TeamId}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Label.Committee}" />
                    <ComboBox ItemsSource="{Binding Committees}" DisplayMemberPath="Name" SelectedValuePath="CommitteeId" SelectedValue="{Binding Discussion.CommitteeId}" />
                </StackPanel>

                <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,8,12,0">
                    <TextBlock Text="{DynamicResource Label.StartTime}" />
                    <TextBox Text="{Binding Discussion.StartTime}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Label.EndTime}" />
                    <TextBox Text="{Binding Discussion.EndTime}" />
                </StackPanel>

                <StackPanel Grid.ColumnSpan="2" Grid.Row="3" Margin="0,8,0,0">
                    <TextBlock Text="{DynamicResource Label.Place}" />
                    <TextBox Text="{Binding Discussion.Place}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
