<Window x:Class="Masar.UI.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Title.About}"
        Height="320"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Style="{StaticResource CardStyle}" Margin="12">
        <StackPanel>
            <TextBlock Text="{Binding AppName}" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,12" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource About.VersionLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Version}" Margin="8,0,0,0" />
            </StackPanel>

            <Border Background="#F8FAFC" Padding="12" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding Developer}" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource Button.Close}" Command="{Binding CloseCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
