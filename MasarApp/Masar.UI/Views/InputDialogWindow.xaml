<Window x:Class="Masar.UI.Views.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="260" Width="420" WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Prompt}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,12" />
            <TextBox Text="{Binding InputText}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
