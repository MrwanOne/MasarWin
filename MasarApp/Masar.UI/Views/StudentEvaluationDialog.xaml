<Window x:Class="Masar.UI.Views.StudentEvaluationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource Title.Evaluation}" Height="600" Width="700" WindowStartupLocation="CenterOwner"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Title.StudentEvaluation}" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Margin="0,8,0,0">
                <Run Text="{DynamicResource Label.Student}" />
                <Run Text=": " />
                <Run Text="{Binding StudentName}" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock>
                <Run Text="{DynamicResource Label.Team}" />
                <Run Text=": " />
                <Run Text="{Binding Discussion.TeamName}" />
            </TextBlock>
        </StackPanel>

        <!-- Criteria List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CriteriaItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Criterion Name -->
                                <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" FontSize="14"
                                           Text="{Binding NameAr}" />

                                <!-- Score Input -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="60" TextAlignment="Center" />
                                    <TextBlock Text=" / " VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding MaxScore}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </StackPanel>

                                <!-- Description -->
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding DescriptionAr}" 
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"
                                           TextWrapping="Wrap" />

                                <!-- Comments -->
                                <TextBox Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                         Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                                         Height="40" AcceptsReturn="True" TextWrapping="Wrap"
                                         ToolTip="{DynamicResource Placeholder.Comments}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Additional Fields -->
        <Grid Grid.Row="2" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Total Score Display -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#E8F5E9" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource Label.TotalScore}" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Text=": " FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalScore}" FontSize="24" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" />
                    <TextBlock Text=" / " FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding MaxTotalScore}" FontSize="16" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Contribution Percentage -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="{DynamicResource Label.ContributionPercentage}" Margin="0,0,0,4" />
                <TextBox Text="{Binding ContributionPercentage, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- General Feedback -->
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="{DynamicResource Label.GeneralFeedback}" Margin="0,0,0,4" />
                <TextBox Text="{Binding GeneralFeedback, UpdateSourceTrigger=PropertyChanged}" Height="60" 
                         AcceptsReturn="True" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Strength Points -->
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,12,8,0">
                <TextBlock Text="{DynamicResource Label.StrengthPoints}" Margin="0,0,0,4" />
                <TextBox Text="{Binding StrengthPoints, UpdateSourceTrigger=PropertyChanged}" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Improvement Areas -->
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,12,0,0">
                <TextBlock Text="{DynamicResource Label.ImprovementAreas}" Margin="0,0,0,4" />
                <TextBox Text="{Binding ImprovementAreas, UpdateSourceTrigger=PropertyChanged}" Height="60"
                         AcceptsReturn="True" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Width="120" Margin="0,0,8,0" />
            <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" Width="120" />
        </StackPanel>
    </Grid>
</Window>
