<Window x:Class="Masar.UI.Views.UserDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Masar.UI.Controls" Title="{DynamicResource Title.User}" Height="480" Width="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="{DynamicResource Title.UserDetails}" FontSize="18" FontWeight="SemiBold" />

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Full Name (Hidden for Admin) -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12" Visibility="{Binding FullNameVisibility}">
                    <TextBlock Text="{DynamicResource Label.FullName}" Margin="0,0,0,6" FontWeight="Medium" />
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" />
                    <TextBlock Text="{DynamicResource Label.FullNameHint}" Margin="0,4,0,0" FontSize="11" Foreground="Gray" />
                </StackPanel>

                <!-- Row 1: User Type (Student, Doctor, or Admin) -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource Label.UserType}" Margin="0,0,0,6" FontWeight="Medium" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource Label.Student}" IsChecked="{Binding IsStudent}" Margin="0,0,20,0" GroupName="UserType" />
                        <RadioButton Content="{DynamicResource Label.Doctor}" IsChecked="{Binding IsDoctor}" Margin="0,0,20,0" GroupName="UserType" />
                        <RadioButton Content="{DynamicResource Label.Admin}" IsChecked="{Binding IsAdmin}" GroupName="UserType" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 2: Doctor Role (Conditional) -->
                <StackPanel Grid.Row="2" Margin="0,0,0,12" Visibility="{Binding DoctorRoleVisibility}">
                    <TextBlock Text="{DynamicResource Label.DoctorRole}" Margin="0,0,0,6" FontWeight="Medium" />
                    <ComboBox ItemsSource="{Binding DoctorRoleOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedDoctorRole}" Padding="10,8" />
                </StackPanel>

                <!-- Row 3: Username and Password -->
                <Grid Grid.Row="3" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="{DynamicResource Label.Username}" Margin="0,0,0,6" FontWeight="Medium" />
                        <TextBox Text="{Binding User.Username}" Padding="10,8" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{DynamicResource Label.PasswordNewUser}" Margin="0,0,0,6" FontWeight="Medium" />
                        <PasswordBox controls:PasswordBoxAssistant.BindPassword="True" controls:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay}" Padding="10,8" />
                    </StackPanel>
                </Grid>

                <!-- Row 4: Active -->
                <StackPanel Grid.Row="4">
                    <CheckBox IsChecked="{Binding User.IsActive}" Content="{DynamicResource Label.Active}" FontWeight="Medium" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="{DynamicResource Button.Save}" Command="{Binding SaveCommand}" Margin="0,0,8,0" Padding="24,10" />
                <Button Content="{DynamicResource Button.Cancel}" Command="{Binding CancelCommand}" Style="{StaticResource GhostButtonStyle}" Padding="24,10" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
