<Window x:Class="Masar.UI.Views.ReportPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="{DynamicResource Title.ReportPreview}" Height="700" Width="1000" MinHeight="500" MinWidth="800" MaxHeight="900" MaxWidth="1400" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource CardStyle}" Padding="16,12" Grid.Row="0" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="{DynamicResource Title.ReportPreview}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" DockPanel.Dock="Left" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource Button.ExportPdf}" Command="{Binding ExportCommand}" Margin="0,0,8,0" Padding="16,8" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button Content="{DynamicResource Button.Print}" Command="{Binding PrintCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="{DynamicResource Button.Close}" Command="{Binding CloseCommand}" Style="{StaticResource GhostButtonStyle}" Padding="16,8" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Document Viewer -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <FlowDocumentScrollViewer Document="{Binding Document}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="White" />
        </Border>
    </Grid>
</Window>
