<Window x:Class="Masar.UI.Views.DepartmentPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="300" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Border Style="{StaticResource CardStyle}" Margin="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" />

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="{Binding Instruction}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,12" />

                <ComboBox ItemsSource="{Binding Departments}"
                          SelectedItem="{Binding SelectedDepartment}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ., Converter={StaticResource LocalizedNameConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- HOD hint for selected dept -->
                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource MutedTextBrush}"
                           Visibility="{Binding SelectedDepartment, Converter={StaticResource BoolToVisibility}}">
                    <Run Text="رئيس القسم الحالي: " />
                    <Run Text="{Binding SelectedDepartment.HeadOfDepartmentName, TargetNullValue='لا يوجد'}" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="{DynamicResource Button.Save}"
                        Command="{Binding ConfirmCommand}"
                        Margin="0,0,8,0" />
                <Button Content="{DynamicResource Button.Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GhostButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
