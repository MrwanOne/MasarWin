<Application x:Class="Masar.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:Masar.UI.Views"
    xmlns:vm="clr-namespace:Masar.UI.ViewModels"
    xmlns:local="clr-namespace:Masar.UI.Converters" ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml" />
                <ResourceDictionary Source="Resources/Strings.ar.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FlowDirection x:Key="AppFlowDirection">RightToLeft</FlowDirection>

            <Style TargetType="{x:Type Window}">
                <Setter Property="FlowDirection" Value="{DynamicResource AppFlowDirection}" />
            </Style>

            <local:FileSizeConverter x:Key="FileSizeConverter" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CollegesViewModel}">
                <views:CollegesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DepartmentsViewModel}">
                <views:DepartmentsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DoctorsViewModel}">
                <views:DoctorsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProjectsViewModel}">
                <views:ProjectsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:StudentsViewModel}">
                <views:StudentsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TeamsViewModel}">
                <views:TeamsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CommitteesViewModel}">
                <views:CommitteesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DiscussionsViewModel}">
                <views:DiscussionsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <views:ReportsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:UsersViewModel}">
                <views:UsersView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AcademicTermsViewModel}">
                <views:AcademicTermsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
                <views:AuditLogView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DocumentsViewModel}">
                <views:DocumentsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
