<UserControl x:Class="Masar.UI.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Masar.UI.Converters"
             x:Name="Root">
    
    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StatusToTextConverter x:Key="StatusToText"/>
        <converters:StatusToIconConverter x:Key="StatusToIcon"/>
    </UserControl.Resources>
    
    <Border CornerRadius="12" 
            Padding="10,5"
            Background="{Binding Status, ElementName=Root, Converter={StaticResource StatusToColor}}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <!-- الأيقونة -->
            <TextBlock Text="{Binding Status, ElementName=Root, Converter={StaticResource StatusToIcon}}" 
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       FontSize="12"/>
            
            <!-- النص -->
            <TextBlock Text="{Binding Status, ElementName=Root, Converter={StaticResource StatusToText}}" 
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
