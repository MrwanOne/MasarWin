<Window x:Class="Masar.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource App.MainTitle}" Height="800" Width="1280" WindowStartupLocation="CenterScreen"
        FlowDirection="{DynamicResource AppFlowDirection}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="212*"/>
            <RowDefinition Height="205*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#0F172A" Grid.Column="0" Grid.RowSpan="2">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="16" DockPanel.Dock="Top">
                    <Border Width="64" Height="64" CornerRadius="16" Background="#1E293B" HorizontalAlignment="Left">
                        <Image Source="/Masar.UI;component/Resources/Images/logo.png"
                               Width="64" Height="64" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{DynamicResource App.Name}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <TextBlock Text="{DynamicResource App.ProductSubtitle}" Foreground="#94A3B8" FontSize="12" />
                </StackPanel>

                <StackPanel Margin="16" DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RoleName}" Foreground="#94A3B8" FontSize="12" />
                    <Button Content="{DynamicResource Main.Logout}" Margin="0,12,0,0" Command="{Binding LogoutCommand}" Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigation}" Background="Transparent" BorderThickness="0" Margin="8" Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="8" Margin="0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" />
                                    <TextBlock Text="{Binding Title}" Margin="8,0,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White" Padding="16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedNavigation.Title}" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock Text="{DynamicResource App.HeaderSubtitle}" FontSize="12" Foreground="#64748B" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content=""
                                Command="{Binding ShowAboutCommand}"
                                Style="{StaticResource GhostButtonStyle}"
                                Padding="10,4"
                                FontFamily="Segoe MDL2 Assets"
                                ToolTip="{DynamicResource Main.About}"
                                Margin="0,0,8,0" />
                        <Button Content="{DynamicResource Language.Toggle}" Command="{Binding ToggleLanguageCommand}"
                                Style="{StaticResource GhostButtonStyle}" Padding="12,4" />
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="16" />
        </Grid>
    </Grid>
</Window>
