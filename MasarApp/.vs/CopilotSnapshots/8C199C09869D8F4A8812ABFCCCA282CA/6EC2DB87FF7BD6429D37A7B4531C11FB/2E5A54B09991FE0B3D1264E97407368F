<Window x:Class="Masar.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Masar - Graduation Project Management System" Height="850" Width="1280" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#0F172A" Grid.Column="0">
            <DockPanel LastChildFill="True">
                <StackPanel Margin="16" DockPanel.Dock="Top">
                    <Border Width="48" Height="48" CornerRadius="12" Background="#1E293B" HorizontalAlignment="Left">
                        <Image Source="/Masar.UI;component/Resources/masar.png"
                               Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Masar" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <TextBlock Text="Graduation Project" Foreground="#94A3B8" FontSize="12" />
                </StackPanel>

                <StackPanel Margin="16" DockPanel.Dock="Bottom">
                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RoleName}" Foreground="#94A3B8" FontSize="12" />
                    <Button Content="Logout" Margin="0,12,0,0" Command="{Binding LogoutCommand}" Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}" SelectedItem="{Binding SelectedNavigation}" Background="Transparent" BorderThickness="0" Margin="8" Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="8" Margin="0,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16" Width="24" />
                                    <TextBlock Text="{Binding Title}" Margin="8,0,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E293B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="White" Padding="16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedNavigation.Title}" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="Masar – Graduation Project Management System" FontSize="12" Foreground="#64748B" />
                </StackPanel>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" Margin="16" />
        </Grid>
    </Grid>
</Window>
